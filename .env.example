NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by local Supabase config when Google OAuth is enabled for supabase
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Used by local Supabase config when phone OTP is enabled for supabase.
# Use real Twilio values for actual SMS delivery. Local test OTP can use
# placeholder values with phone +15555550100 and code 123456.
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
